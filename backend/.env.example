# ── Required ────────────────────────────────────────────────
# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/stellaredupay

# ── Stellar Network ──────────────────────────────────────────
# "testnet" (default) or "mainnet"
STELLAR_NETWORK=testnet

# Optional: override the Horizon API URL
# HORIZON_URL=https://horizon-testnet.stellar.org

# Optional: USDC issuer address (defaults to well-known testnet/mainnet issuer)
# USDC_ISSUER=G...

# ── Server ───────────────────────────────────────────────────
PORT=5000

# ── Polling ──────────────────────────────────────────────────
# Background job interval in milliseconds (default: 30000)
POLL_INTERVAL_MS=30000

# ── Retry / Outage Recovery ───────────────────────────────────
RETRY_INTERVAL_MS=60000
RETRY_MAX_ATTEMPTS=10

# ── Payment Limits ─────────────────────────────────────────────
# Minimum payment amount in XLM/USDC (default: 0.01)
MIN_PAYMENT_AMOUNT=0.01

# Maximum payment amount in XLM/USDC (default: 100000)
MAX_PAYMENT_AMOUNT=100000
# ── Migration only ───────────────────────────────────────────
# Only needed when running scripts/migrate-default-school.js to seed
# the first school from a pre-multi-school deployment.
# Not required for normal server operation.
# SCHOOL_WALLET_ADDRESS=G...
# ── Timeouts ──────────────────────────────────────────────────
# Maximum time (ms) for an inbound HTTP request before the server returns 503 (default: 30000)
REQUEST_TIMEOUT_MS=30000

# Maximum time (ms) for a single outbound Stellar Horizon API call (default: 10000)
STELLAR_TIMEOUT_MS=10000
